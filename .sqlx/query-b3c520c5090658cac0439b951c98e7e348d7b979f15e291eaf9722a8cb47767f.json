  "query": "\n            SELECT id, agent_id, input, expected,\n                   difficulty as \"difficulty: String\",\n                   domain,\n                   source as \"source: String\",\n                   tags, created_at\n            FROM scenarios\n            WHERE agent_id = $1\n            ORDER BY created_at DESC\n            LIMIT $2\n            ",
