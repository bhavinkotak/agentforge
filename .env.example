# AgentForge Environment Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgres://agentforge:agentforge@localhost:5432/agentforge

# Redis
REDIS_URL=redis://localhost:6379

# Server
AGENTFORGE_HOST=127.0.0.1
AGENTFORGE_PORT=8080
AGENTFORGE_LOG_LEVEL=info

# LLM API Keys (required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# LLM Judge Configuration
# The judge model MUST differ from any agent model to prevent circular bias
AGENTFORGE_JUDGE_PROVIDER=openai
AGENTFORGE_JUDGE_MODEL=gpt-4o

# Eval Defaults
AGENTFORGE_DEFAULT_SCENARIOS=100
AGENTFORGE_MAX_SCENARIOS=2000
AGENTFORGE_DEFAULT_CONCURRENCY=10
AGENTFORGE_DEFAULT_PASS_THRESHOLD=0.85

# Optimizer
AGENTFORGE_OPTIMIZER_VARIANTS_MIN=5
AGENTFORGE_OPTIMIZER_VARIANTS_MAX=20

# Promotion Gate Defaults
AGENTFORGE_SCORE_GATE_DELTA=0.03
AGENTFORGE_REGRESSION_GATE_THRESHOLD=0.99
AGENTFORGE_STABILITY_SEEDS=3
